#!/usr/bin/env sh
# Run local quality checks before push.

if [ -x ".venv/Scripts/python.exe" ]; then
  PYTHON=".venv/Scripts/python.exe"
elif command -v python >/dev/null 2>&1; then
  PYTHON="python"
else
  echo "python executable not found; cannot run pre-push checks."
  exit 1
fi

"$PYTHON" scripts/run_checks.py
status=$?

if [ $status -ne 0 ]; then
  echo "Push blocked: checks failed."
  exit $status
fi

exit 0
